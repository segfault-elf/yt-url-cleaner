{
  "manifest_version": 3,
  "name": "YoutubeURLCleaner",
  "version": "1.0.0",
  "description": "Cleans YouTube URLs from trackers automatically.",
  "permissions": ["scripting", "tabs"],
  "host_permissions": ["*://*.youtube.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/16x16.png",
    "48": "icons/48x48.png",
    "128": "icons/128x128.png"
  }
}